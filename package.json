{
  "name": "safenet-staking-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "deploy:ipfs": "node --env-file-if-exists=.env scripts/deploy-ipfs.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
    "prepare": "husky",
    "generate:proofs": "tsx scripts/generate-merkle-tree.ts"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "5.2.8",
    "@fontsource-variable/geist-mono": "5.2.7",
    "@plausible-analytics/tracker": "0.4.4",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tanstack/react-query": "5.96.0",
    "@walletconnect/ethereum-provider": "2.23.9",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.7.0",
    "ox": "0.14.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "7.13.2",
    "recharts": "3.8.1",
    "tailwind-merge": "3.5.0",
    "viem": "2.47.6",
    "wagmi": "3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.58.2",
    "@tailwindcss/vite": "4.2.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.10.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-basic-ssl": "2.1.4",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "jsdom": "28.1.0",
    "pinata": "2.5.5",
    "tailwindcss": "4.2.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.0",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  },
  "resolutions": {
    "@reown/appkit": "1.8.18"
  }
}
